{
  "name": "@stay-ops/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "eslint .",
    "test": "node ../../packages/sync/node_modules/typescript/lib/tsc.js -p ../../packages/sync/tsconfig.json && vitest run --no-file-parallelism",
    "test:integration": "vitest run --project integration",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep \"@smoke\"",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@stay-ops/audit": "workspace:*",
    "@stay-ops/db": "workspace:*",
    "@stay-ops/shared": "workspace:*",
    "@stay-ops/sync": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "bullmq": "^5.34.5",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.6",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
