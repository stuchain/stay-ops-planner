# Copy this file to `.env.hosthub.local` (gitignored) at the repo root and set your key.
# The sync worker loads this file automatically before reading other env (shell/Docker still wins).
# Never commit `.env.hosthub.local`.

HOSTHUB_API_TOKEN=
