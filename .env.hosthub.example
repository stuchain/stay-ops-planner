# Copy this file to `.env.hosthub.local` (gitignored) at the repo root and set your key.
# The sync worker loads this file automatically before reading other env (shell/Docker still wins).
# Never commit `.env.hosthub.local`.

HOSTHUB_API_TOKEN=
# Optional (defaults match @stay-ops/sync)
# HOSTHUB_API_BASE=https://app.hosthub.com/api/2019-03-01
# Optional: paginate all calendar rows and print JSON counts — pnpm hosthub:count-bookings
# Same UTC overlap rule as Settings / GET /api/excel/listings?year= — pnpm hosthub:count-bookings -- --overlap-year 2026
# HOSTHUB_API_RESERVATIONS_PATH=/calendar-events
# HOSTHUB_CALENDAR_EVENTS_IS_VISIBLE=all
