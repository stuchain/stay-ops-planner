# Copy to `.env` / `.env.local` for local development (never commit real secrets).
# `apps/web` loads repo-root `.env` / `.env.local` via `next.config.ts` (so DATABASE_URL here applies to Next API routes).

# ---------------------------------------------------------------------------
# Production readiness matrix (Vercel + Neon no-worker path)
# Required before ship:
# - DATABASE_URL (owner: platform/deploy)
# - SESSION_SECRET (owner: platform/deploy)
# - APP_TIMEZONE (owner: operations)
# - BOOTSTRAP_ADMIN_EMAIL / BOOTSTRAP_ADMIN_PASSWORD (owner: operations)
# - BOOTSTRAP_FATHER_EMAIL / BOOTSTRAP_FATHER_PASSWORD (owner: operations; EPICS S4 household co-account)
#   Optional: BOOTSTRAP_FATHER_ROLE = viewer | operator | admin (default operator)
# - HOSTHUB_* + WEBHOOK_SECRET (owner: integrations)
# Optional observability baseline:
# - SENTRY_DSN, NEXT_PUBLIC_SENTRY_DSN, SENTRY_ENVIRONMENT, SENTRY_RELEASE,
#   SENTRY_USER_ID_PEPPER (owner: operations)
# Source of truth for required env validation:
# packages/shared/src/env.ts
# ---------------------------------------------------------------------------

# PostgreSQL (host machine connecting to Docker Compose: use localhost and mapped port)
DATABASE_URL=postgresql://stayops:stayops@localhost:5432/stayops
# Vercel + Neon (serverless): use the pooled connection string (hostname usually contains "pooler").
# Keep `?sslmode=require` if Neon provides it. Wrong host (direct vs pooler) or a suspended Neon project
# yields `GET /api/health/ready` → 503 with checks.issue / checks.prismaCode (see production deploy runbook).
# On Vercel, enable DATABASE_URL for Build + Runtime: `apps/web/vercel.json` runs `prisma migrate deploy`
# during the build; Runtime-only DATABASE_URL makes the build fail at migrate.
# Set per-environment URLs in the Vercel dashboard; use a separate Preview DB when Preview must not migrate production.
# Dedicated integration test DB (prevents tests touching your main local DB)
TEST_DATABASE_URL=postgresql://stayops:stayops@localhost:5432/stayops_test

# Redis
REDIS_URL=redis://localhost:6379

# Session signing (required once env validation is enabled; use 32+ random bytes in production)
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# Cookie Secure flag: auto (HTTPS cookies only in production) | true | false
SESSION_COOKIE_SECURE=auto

# Bootstrap users (production / staging): set both admin and father pairs, then
#   pnpm --filter @stay-ops/db seed
# (Idempotent upsert; re-run overwrites password_hash from env — use intentionally.)
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_FATHER_EMAIL=
# BOOTSTRAP_FATHER_PASSWORD=
# BOOTSTRAP_FATHER_ROLE=operator
#
# Optional local-only dev admin (never in production): after migrate, seed with STAYOPS_DEV_ADMIN=1
# creates admin@stayops.local / admin
# STAYOPS_DEV_ADMIN=1

# IANA timezone for scheduling and display
APP_TIMEZONE=Etc/UTC

# Logging (optional)
# LOG_LEVEL=info

# Hosthub — see https://www.hosthub.com/docs/api/ and docs/vendor/hosthub-api.md
# Gitignored Hosthub key file (repo root): copy .env.hosthub.example → .env.hosthub.local
# Loaded by `pnpm hosthub:smoke` and by the sync worker on startup (existing env vars win).
# HOSTHUB_API_BASE=https://app.hosthub.com/api/2019-03-01
# HOSTHUB_API_TOKEN=
# List path after base (default /calendar-events in @stay-ops/sync HosthubClient)
# HOSTHUB_API_RESERVATIONS_PATH=/calendar-events
# Incremental sync uses sync_run cursor as updated_gte. For a full history pull:
# HOSTHUB_RECONCILE_FULL_SYNC=1
# Include hidden/deleted calendar rows (Hosthub is_visible=all) — optional
# HOSTHUB_CALENDAR_EVENTS_IS_VISIBLE=all
# Skip per-event notes + GR-tax HTTP calls during reconcile (faster)
# HOSTHUB_SYNC_FETCH_EVENT_ENRICHMENT=0
# After global /calendar-events, also GET /rentals/{id}/calendar-events per rental (high API load)
# HOSTHUB_RECONCILE_PER_RENTAL_CALENDAR=1
# HMAC of raw POST body; default header x-hosthub-signature, value sha256=<hex> (override if docs differ)
# HOSTHUB_WEBHOOK_SIGNATURE_HEADER=x-hosthub-signature
# WEBHOOK_SECRET=

# --- Sentry (Epic 2) — optional locally; CI uses secrets for release + sourcemaps ---
# Server DSN (never expose in client bundles)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Browser DSN (safe to expose)
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=development
# Semantic release id (CI should set from apps/web package version, e.g. stay-ops-web@0.1.0)
# SENTRY_RELEASE=stay-ops-web@0.1.0
# Optional pepper for hashed user id in Sentry (recommended in production)
# SENTRY_USER_ID_PEPPER=
# CI-only (GitHub Actions secrets): SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT
