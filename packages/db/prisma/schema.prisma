generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  needs_reassignment
}

enum Channel {
  airbnb
  booking
  direct
}

enum AlertConfigChannel {
  whatsapp
  sms
}

enum AlertConfigEventType {
  sync_run_failed
  unassigned_backlog_threshold_reached
  cleaning_overdue
  conflict_resolution_required
}

enum OperationalThresholdKey {
  unassigned_backlog_count
  unassigned_backlog_window_hours
  cleaning_overdue_minutes
  conflict_resolution_sla_minutes
  sync_failure_suppression_minutes
}

enum UserRole {
  viewer
  operator
  admin
}

enum UiLocale {
  en
  el
}

/// Internal operator identity (Phase 1). Optional FKs on assignments and audit.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(operator)
  uiLocale     UiLocale @default(en) @map("ui_locale")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assignmentsCreated Assignment[] @relation("AssignmentCreatedBy")
  assignmentsUpdated Assignment[] @relation("AssignmentUpdatedBy")
  auditEvents        AuditEvent[]

  @@map("users")
}

/// Physical unit in the property (R1…RN in fixtures).
model Room {
  id                  String   @id @default(cuid())
  code                String?  @unique
  displayName         String?  @map("display_name")
  isActive            Boolean  @default(true) @map("is_active")
  /// Lower sorts first on calendar; null sorts after set values.
  calendarSortIndex   Int?     @map("calendar_sort_index")
  /// Max sleeping guests; null means no capacity limit for proposals.
  maxGuests           Int?     @map("max_guests")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  assignments   Assignment[]
  manualBlocks  ManualBlock[]
  cleaningTasks CleaningTask[]

  @@map("rooms")
}

/// Channel listing as seen from the provider (Hosthub listing id, etc.).
model SourceListing {
  id                 String   @id @default(cuid())
  channel            Channel
  externalListingId  String   @map("external_listing_id")
  title              String?
  /// Tax ledger rental bucket 1–4 (Onar/Cosmos/Iris/Helios); set from Hosthub listing, editable in admin.
  rentalIndex        Int?     @map("rental_index")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  bookings Booking[]

  @@unique([channel, externalListingId], map: "source_listings_channel_external_listing_id_key")
  @@map("source_listings")
}

/// Singleton row (id=1): labels for the four rental columns on the Excel tax ledger.
model ExcelRentalConfig {
  id        Int      @id @default(1)
  label1    String   @default("Onar")
  label2    String   @default("Cosmos")
  label3    String   @default("Iris")
  label4    String   @default("Helios")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("excel_rental_config")
}

/// Canonical booking row; `raw_payload` stores provider JSON for Phase 3 mapping.
model Booking {
  id                String   @id @default(cuid())
  sourceListingId   String?  @map("source_listing_id")
  channel           Channel
  externalBookingId String   @map("external_booking_id")
  status            BookingStatus
  checkinDate       DateTime @db.Date @map("checkin_date")
  checkoutDate      DateTime @db.Date @map("checkout_date")
  nights            Int
  guestName         String?  @map("guest_name")
  guestEmail        String?  @map("guest_email")
  guestPhone        String?  @map("guest_phone")
  guestAdults       Int?     @map("guest_adults")
  guestChildren     Int?     @map("guest_children")
  guestInfants      Int?     @map("guest_infants")
  guestTotal        Int?     @map("guest_total")
  totalAmountCents  Int?     @map("total_amount_cents")
  currency          String?  @map("currency")
  cleaningFeeCents  Int?     @map("cleaning_fee_cents")
  taxCents          Int?     @map("tax_cents")
  payoutAmountCents Int?     @map("payout_amount_cents")
  guestPaidCents    Int?     @map("guest_paid_cents")
  action            String?  @map("action")
  notes             String?  @map("notes")
  hosthubCalendarEventRaw Json? @map("hosthub_calendar_event_raw")
  hosthubNotesRaw   Json?    @map("hosthub_notes_raw")
  hosthubGrTaxesRaw Json?    @map("hosthub_gr_taxes_raw")
  rawPayload        Json?    @map("raw_payload")
  /// Optimistic concurrency for API PATCH / assignment flows that pass `expectedVersion`.
  version           Int      @default(0)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  sourceListing SourceListing? @relation(fields: [sourceListingId], references: [id], onDelete: SetNull)
  assignment    Assignment?
  cleaningTasks CleaningTask[]
  excelLedgerEntries ExcelLedgerEntry[]

  @@index([checkinDate, checkoutDate])
  @@index([status])
  @@unique([channel, externalBookingId], map: "bookings_channel_external_booking_id_key")
  @@map("bookings")
}

/// Per-year tax ledger overrides for the Excel page (manual cells + per-cell overrides of auto-filled values).
model ExcelLedgerEntry {
  id         String   @id @default(cuid())
  year       Int
  bookingId  String?  @map("booking_id")
  manualName String?  @map("manual_name")
  manualMonth Int?    @map("manual_month")
  overrides  Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@unique([year, bookingId], map: "excel_ledger_entries_year_booking_id_key")
  @@index([year], map: "excel_ledger_entries_year_idx")
  @@map("excel_ledger_entries")
}

/// At most one assignment per booking in v1 (`booking_id` unique).
model Assignment {
  id          String   @id @default(cuid())
  bookingId   String   @unique @map("booking_id")
  roomId      String   @map("room_id")
  startDate   DateTime @db.Date @map("start_date")
  endDate     DateTime @db.Date @map("end_date")
  version     Int      @default(0)
  createdById String?  @map("created_by_id")
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room      Room    @relation(fields: [roomId], references: [id], onDelete: Restrict)
  createdBy User?   @relation("AssignmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?   @relation("AssignmentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([roomId, startDate, endDate])
  @@map("assignments")
}

model ManualBlock {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  startDate DateTime @db.Date @map("start_date")
  endDate   DateTime @db.Date @map("end_date")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, startDate, endDate])
  @@map("manual_blocks")
}

model CleaningTask {
  id              String    @id @default(cuid())
  bookingId       String    @map("booking_id")
  roomId          String    @map("room_id")
  status          String    @default("todo")
  notes           String?
  /// turnover | service (Phase 5).
  taskType        String    @default("turnover") @map("task_type")
  /// Idempotency key; unique when set. Turnover uses SHA-256(bookingId|checkoutDay|roomId|turnover).
  sourceEventId   String?   @unique @map("source_event_id")
  plannedStart    DateTime? @map("planned_start")
  plannedEnd      DateTime? @map("planned_end")
  assigneeName    String?   @map("assignee_name")
  durationMinutes Int?      @map("duration_minutes")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room    Room    @relation(fields: [roomId], references: [id], onDelete: Restrict)

  @@index([bookingId, taskType])
  @@map("cleaning_tasks")
}

model SyncRun {
  id          String    @id @default(cuid())
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  status      String?
  source      String?
  /// Aggregated counters: fetched, upserted, errors, skipped (Phase 3).
  statsJson   Json?     @map("stats_json")
  /// Opaque pagination cursor for the next Hosthub poll (optional).
  cursor      String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  importErrors ImportError[]

  @@map("sync_runs")
}

model ImportError {
  id        String   @id @default(cuid())
  syncRunId String   @map("sync_run_id")
  code      String?
  message   String
  payload   Json?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  syncRun SyncRun @relation(fields: [syncRunId], references: [id], onDelete: Cascade)

  @@index([resolved, createdAt])
  @@map("import_errors")
}

/// Idempotent webhook deliveries (Phase 3). Unique dedupe_key ensures at-most-once enqueue per provider event.
model WebhookInboundEvent {
  id          String   @id @default(cuid())
  provider    String
  dedupeKey   String   @unique @map("dedupe_key")
  payloadHash String?  @map("payload_hash")
  receivedAt  DateTime @default(now()) @map("received_at")

  @@map("webhook_inbound_events")
}

/// Client idempotency (Epic 6): same scope + key + user replays cached JSON response within TTL window.
model IdempotencyKey {
  id           String   @id @default(cuid())
  scope        String
  key          String
  userId       String   @map("user_id")
  requestHash  String   @map("request_hash")
  statusCode   Int?     @map("status_code")
  responseBody Json?    @map("response_body")
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  @@unique([scope, key, userId], map: "idempotency_keys_scope_key_user_id_key")
  @@index([expiresAt], map: "idempotency_keys_expires_at_idx")
  @@map("idempotency_keys")
}

/// Login outcomes for brute-force detection (Epic 7).
model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String
  succeeded Boolean
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, createdAt], map: "login_attempts_email_created_at_idx")
  @@index([ip, createdAt], map: "login_attempts_ip_created_at_idx")
  @@map("login_attempts")
}

/// Fixed-window rate limit counters (Epic 7).
model RateLimitCounter {
  scope       String
  bucketKey   String   @map("bucket_key")
  windowStart DateTime @map("window_start")
  count       Int      @default(0)

  @@id([scope, bucketKey, windowStart], map: "rate_limit_counters_pkey")
  @@index([windowStart], map: "rate_limit_counters_window_start_idx")
  @@map("rate_limit_counters")
}

model AuditEvent {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  payload    Json?
  beforeJson Json?    @map("before_json")
  afterJson  Json?    @map("after_json")
  metaJson   Json?    @map("meta_json")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, createdAt])
  @@index([entityId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_events")
}

model AlertTemplateConfig {
  id              String               @id @default(cuid())
  eventType       AlertConfigEventType @map("event_type")
  channel         AlertConfigChannel
  templateVersion Int                  @default(1) @map("template_version")
  title           String?
  body            String
  enabled         Boolean              @default(true)
  metaJson        Json?                @map("meta_json")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@unique([eventType, channel, templateVersion], map: "alert_template_configs_event_channel_version_key")
  @@index([eventType, channel, enabled], map: "alert_template_configs_event_channel_enabled_idx")
  @@map("alert_template_configs")
}

model OperationalThresholdConfig {
  id           String                 @id @default(cuid())
  key          OperationalThresholdKey @map("key_name")
  numericValue Decimal?               @db.Decimal(12, 3) @map("numeric_value")
  stringValue  String?                @map("string_value")
  unit         String?
  notes        String?
  enabled      Boolean                @default(true)
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  @@unique([key], map: "operational_threshold_configs_key_name_key")
  @@index([enabled], map: "operational_threshold_configs_enabled_idx")
  @@map("operational_threshold_configs")
}

model IntegrationSecret {
  id         String   @id @default(cuid())
  provider   String
  secretKey  String   @map("secret_key")
  displayName String? @map("display_name")
  ciphertext String
  iv         String
  tag        String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([provider, secretKey], map: "integration_secrets_provider_secret_key_key")
  @@map("integration_secrets")
}
