{
  "name": "@stay-ops/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "prisma db seed",
    "seed:e2e": "tsx prisma/seed-e2e.ts",
    "retention:prune": "node ./scripts/retention-prune.mjs",
    "build": "prisma generate && tsc",
    "lint": "eslint .",
    "test": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.19.17",
    "eslint": "^9.16.0",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
