{
  "name": "@stay-ops/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./observability": {
      "types": "./dist/observability/index.d.ts",
      "import": "./dist/observability/index.js",
      "default": "./dist/observability/index.js"
    },
    "./observability/redact": {
      "types": "./dist/observability/redact.d.ts",
      "import": "./dist/observability/redact.js",
      "default": "./dist/observability/redact.js"
    },
    "./observability/hash-user-id": {
      "types": "./dist/observability/hashUserId.d.ts",
      "import": "./dist/observability/hashUserId.js",
      "default": "./dist/observability/hashUserId.js"
    },
    "./retry": {
      "types": "./dist/retry/index.d.ts",
      "import": "./dist/retry/index.js",
      "default": "./dist/retry/index.js"
    },
    "./log": {
      "types": "./dist/log/log.d.ts",
      "import": "./dist/log/log.js",
      "default": "./dist/log/log.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.5"
  }
}
